const camera_pitch 4 #Up/down rotation
const aspect_ratio 5
const scale_matrix 6
const rotation_matrix 24
const translation_matrix 40
const model_matrix 56
const view_matrix 72
const projection_matrix 98
const temporary_matrix 114
