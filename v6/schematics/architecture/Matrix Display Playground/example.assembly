# Number format "FF" encouraged!
# This program expects 3 arguments
# per operation:
# -------------y-x: Coordinates
# --CCCCCCCCCCCC--: Matrix on what
#                   to toggle
# --------RRGGBB--: Color
# x and y can be 0 to 7.
# C,R,G,B are values from 0 to F.
# Basically, each C pair (CC)
# represents 1 column of the
# selected dot matrix display.
0x0000000000000000 # position
0x0000000000000000 # draw data
0x0000000000000000 # color

# -------------y-x
0x0000000000000401
# --CCCCCCCCCCCC--
0x00FFFFFFFFFFFF00
# --------RRGGBB--
0x00000000FFFFFF00

0x0000000000000101
0x00F0F0F0F0F0F000
0x00000000FFFF0000

0x0000000000000000
0x0088888888888800
0x000000000000FF00

