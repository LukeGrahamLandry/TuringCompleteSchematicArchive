#--Registers/IO---
# 0-7 register 0-7
# 8-255 More Registers
# --- WRITE ONLY ---
# 256 7Seg (4digit number max)
# 257 ---
# 258 gpu_cmd
# 259 gpu_id
# 260 gpu_pos
# 261 gpu_size
# 262 gpu_draw
# ---- READABLE ---
# 512 program counter
# 513 input/output
# 514 counter (write = reset)
# 
const _ 0 #nothing
const v 1 #register or immediate
const d 2 #destination register
const r 3 #ram addr
const p 4 #program destination addr

#0
3 v v d #0 add
3 v v d #1 sub
3 v v d #2 and
