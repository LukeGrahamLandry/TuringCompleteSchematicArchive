3 v v d #7 mul2
3 v v d #8 div
3 v v d #8 mod

#10
2 v d _ # mov
1 d _ _ # inc
1 d _ _ # dec
3 v v d # shl
3 v v d # shr
2 v d _ # sng
2 v d _ # neg
2 v d _ # abs

#18
2 v d _ # cos (0-359)
2 v d _ # sin (0-359)
